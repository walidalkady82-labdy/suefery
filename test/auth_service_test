
// Import the generated mock file
import 'package:firebase_auth/firebase_auth.dart' as firebase;
import 'package:flutter_test/flutter_test.dart';
import 'package:mockito/annotations.dart';
import 'package:mockito/mockito.dart';
import 'package:suefery/data/model/user_model.dart';
import 'package:suefery/data/repository/i_repo_auth.dart';
import 'package:suefery/data/service/auth_service.dart';
import 'package:suefery/data/service/pref_service.dart';

import 'auth_service_test.mocks.dart';

// This tells mockito which classes to generate mocks for.
// You must re-run the build_runner command if you add more.
@GenerateMocks([
  IRepoAuth,
  PrefService,
  firebase.User,
  firebase.UserCredential,
  firebase.UserCredential,
  firebase.AdditionalUserInfo,
  firebase.AuthCredential,
])
void main() {
  // 1. DECLARE YOUR VARIABLES
  // We use "late" because they will be initialized in setUp()
  late AuthService authService;
  late MockIAuthRepository mockAuthRepository;
  late MockPrefsService mockPrefsService;
  late MockUser mockUser;
  late MockUserCredential mockUserCredential;
  late MockAdditionalUserInfo mockUserInfo;
  late MockAuthCredential mockAuthCredential;

  // 2. SET UP
  // This runs BEFORE each test, ensuring a clean state
  setUp(() {
    // Create fresh mocks for each test
    mockAuthRepository = MockIAuthRepository();
    mockPrefsService = MockPrefsService();
    mockUser = MockUser();
    mockUserCredential = MockUserCredential();
    mockUserInfo = MockAdditionalUserInfo();
    mockAuthCredential = MockAuthCredential();

    // Create the "System Under Test" (SUT)
    // We inject the MOCKS, not the real ones!
    authService = AuthService(mockAuthRepository, mockPrefsService);

    // --- Common Mock Setups ---
    // A common setup for a "logged in" user
    when(mockUser.uid).thenReturn('test_uid');
    when(mockUser.email).thenReturn('test@test.com');
    when(mockUser.displayName).thenReturn('Test User');
    when(mockUser.getIdToken()).thenAnswer((_) async => 'test_token');

    // A common setup for `_handleSuccessfulLogin`
    when(mockPrefsService.setUserAuthToken(any))
        .thenAnswer((_) async => Future.value());
    when(mockPrefsService.setUserLoggedInTime(any))
        .thenAnswer((_) async => Future.value());
    when(mockPrefsService.setUserIsLoggedin(true))
        .thenAnswer((_) async => Future.value());

    // A common setup for `_clearUserSession`
    when(mockPrefsService.setUserLoggedOffTime(any))
        .thenAnswer((_) async => Future.value());
    when(mockPrefsService.setUserIsLoggedin(false))
        .thenAnswer((_) async => Future.value());
    when(mockPrefsService.setUserAuthToken(null))
        .thenAnswer((_) async => Future.value());
  });

  group('AuthService - isUserLoggedIn', () {
    test('should return true when prefs are good and user reloads successfully',
        () async {
      // 3. ARRANGE
      // "WHEN" these methods are called... "THEN" return these values.
      when(mockPrefsService.isUserLoggedin).thenAnswer((_) async => true);
      when(mockAuthRepository.currentUser).thenReturn(mockUser);
      when(mockAuthRepository.reloadUser())
          .thenAnswer((_) async => Future.value()); // It succeeds

      // 4. ACT
      final result = await authService.isUserLoggedIn();

      // 5. ASSERT
      expect(result, isTrue);
      // Verify that we *checked* the repo, but *never* tried to log out
      verify(mockAuthRepository.reloadUser()).called(1);
      verifyNever(mockPrefsService.setUserIsLoggedin(false));
    });

    test('should return false and clear session when user reload FAILS',
        () async {
      // 3. ARRANGE
      final testException =
          firebase.FirebaseAuthException(code: 'user-disabled');

      when(mockPrefsService.isUserLoggedin).thenAnswer((_) async => true);
      when(mockAuthRepository.currentUser).thenReturn(mockUser);

      // IMPORTANT: This time, the repo throws an error
      when(mockAuthRepository.reloadUser()).thenThrow(testException);

      // 4. ACT
      final result = await authService.isUserLoggedIn();

      // 5. ASSERT
      expect(result, isFalse);
      // **This is the critical test!**
      // We VERIFY that our service's business logic
      // correctly called the prefs service to log the user out.
      verify(mockAuthRepository.reloadUser()).called(1);
      verify(mockPrefsService.setUserIsLoggedin(false)).called(1);
      verify(mockPrefsService.setUserAuthToken(null)).called(1);
    });

    test('should return false immediately if prefs say not logged in', () async {
      // 3. ARRANGE
      when(mockPrefsService.isUserLoggedin).thenAnswer((_) async => false);

      // 4. ACT
      final result = await authService.isUserLoggedIn();

      // 5. ASSERT
      expect(result, isFalse);
      // Verify that we saved a network call and never touched the repo
      verifyNever(mockAuthRepository.reloadUser());
      verifyNever(mockAuthRepository.currentUser);
    });
  });

  group('AuthService - signInWithGoogle', () {
    test('should save new user and session data on successful sign-in',
        () async {
      // Arrange
      when(mockUserCredential.user).thenReturn(mockUser);
      when(mockUserCredential.additionalUserInfo).thenReturn(mockUserInfo);
      when(mockUserInfo.isNewUser).thenReturn(true);
      when(mockAuthRepository.logInWithGoogle())
          .thenAnswer((_) async => mockUserCredential);
      when(mockPrefsService.setIsFirstLogin(true))
          .thenAnswer((_) async => Future.value());

      // Act
      final appUser = await authService.signInWithGoogle();

      // Assert
      expect(appUser, isA<UserModel>());
      expect(appUser?.id, 'test_uid');
      // Verify `setIsFirstLogin(true)` was called
      verify(mockPrefsService.setIsFirstLogin(true)).called(1);
      // Verify `_handleSuccessfulLogin` was called
      verify(mockPrefsService.setUserAuthToken('test_token')).called(1);
      verify(mockPrefsService.setUserIsLoggedin(true)).called(1);
    });
  });

  group('AuthService - deleteUser', () {
    test('should clear session on successful deletion', () async {
      // Arrange
      when(mockAuthRepository.deleteUser())
          .thenAnswer((_) async => Future.value());

      // Act
      await authService.deleteUser();

      // Assert
      verify(mockAuthRepository.deleteUser()).called(1);
      // Verify `_clearUserSession` was called
      verify(mockPrefsService.setUserIsLoggedin(false)).called(1);
      verify(mockPrefsService.setUserAuthToken(null)).called(1);
    });

    test('should throw error and NOT clear session if deletion fails', () async {
      // Arrange
      final testException =
          firebase.FirebaseAuthException(code: 'requires-recent-login');
      when(mockAuthRepository.deleteUser()).thenThrow(testException);

      // Act
      // We expect this function call to throw an exception
      final futureCall = authService.deleteUser();

      // Assert
      expect(futureCall, throwsA(isA<firebase.FirebaseAuthException>()));
      // Verify session was NOT cleared
      verifyNever(mockPrefsService.setUserIsLoggedin(false));
      verifyNever(mockPrefsService.setUserAuthToken(null));
    });
  });

  group('AuthService - reauthenticateWithGoogle', () {
    test('should call repo to get credential and re-authenticate', () async {
      // Arrange
      when(mockAuthRepository.logInWithGoogle())
          .thenAnswer((_) async => userCredential);
      when(mockAuthRepository.reauthenticateWithCredential(mockAuthCredential))
          .thenAnswer((_) async => Future.value());

      // Act
      await authService.reauthenticateWithGoogle();

      // Assert
      verify(mockAuthRepository.logInWithGoogle()).called(1);
      verify(mockAuthRepository.reauthenticateWithCredential(mockAuthCredential))
          .called(1);
    });
  });
}